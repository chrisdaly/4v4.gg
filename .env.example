# Copy this file to .env.local and fill in your credentials

# Chat relay admin API key (for sending messages)
VITE_CHAT_ADMIN_KEY=your_admin_api_key_here

# Chat relay server URL (fly.io relay is default; use localhost for relay dev)
# VITE_CHAT_RELAY_URL=http://localhost:3002
VITE_CHAT_RELAY_URL=https://4v4gg-chat-relay.fly.dev
