FROM python:3.11-slim

WORKDIR /app

# CPU-only PyTorch (much smaller than full CUDA build)
RUN pip install --no-cache-dir \
    torch --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir numpy tqdm onnx onnxruntime

# Copy training + export scripts and data
COPY train_local.py export_onnx.py .
COPY data/train.bin data/val.bin data/meta.json ./data/

# Keep alive so we can SSH in
CMD ["sleep", "infinity"]
